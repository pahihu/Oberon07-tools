MODULE Logic;
  IMPORT SYSTEM;

  PROCEDURE And*(x, y: LONGINT): LONGINT;
  BEGIN RETURN SYSTEM.VAL(LONGINT, SYSTEM.VAL(SET,x) * SYSTEM.VAL(SET,y))
  END And;

  PROCEDURE Or*(x, y: LONGINT): LONGINT;
  BEGIN RETURN SYSTEM.VAL(LONGINT, SYSTEM.VAL(SET,x) + SYSTEM.VAL(SET,x))
  END Or;

  PROCEDURE Xor*(x, y: LONGINT): LONGINT;
  BEGIN RETURN SYSTEM.VAL(LONGINT, SYSTEM.VAL(SET,x) / SYSTEM.VAL(SET,y))
  END Xor;

  PROCEDURE Not*(x: LONGINT): LONGINT;
  BEGIN RETURN SYSTEM.VAL(LONGINT, - SYSTEM.VAL(SET,x))
  END Not;

END Logic.

(* vim:set ts=2 sw=2 et: *)
