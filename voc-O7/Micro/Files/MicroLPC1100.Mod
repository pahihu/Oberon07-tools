				LPC11C{1,2}{2,4},
				LPC11D14
	*)

	CONST
		(* memory map *)
			flashStart* = 0;
			SRAMStart* = 10000000H;

			(* APB peripherals *)
				I2C* = 40000000H;
					I2C0CONSET* = I2C;
					I2C0STAT* = I2C + 4;
					I2C0DAT* = I2C + 8;
					I2C0ADR0* = I2C + 0CH;
					I2C0SCLH* = I2C + 10H;
