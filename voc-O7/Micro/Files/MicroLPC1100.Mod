					SSP0MIS* = SSP0 + 1CH;
					SSP0ICR* = SSP0 + 20H;
				IOCONFIG* = 40044000H;
					IOCONPIO26* = IOCONFIG;
					IOCONPIO20* = IOCONFIG + 8;
					IOCONRESETPIO00* = IOCONFIG + 0CH;
					IOCONPIO01* = IOCONFIG + 10H;
