						IOCPNSSEL1LOC* = IOCONFIG + 18H;
					IOCONPIO02* = IOCONFIG + 1CH;
					IOCONPIO27* = IOCONFIG + 20H;
					IOCONPIO28* = IOCONFIG + 24H;
