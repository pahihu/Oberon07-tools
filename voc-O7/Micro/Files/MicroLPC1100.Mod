						IOCONCT32B0CAP0LOC* = IOCONFIG + 0D0H;
						IOCONRXDLOC* = IOCONFIG + 0D4H;
				SC* = 40048000H;
					SYSMEMREMAP* = SC; (* system memory map *)
					PRESETCTRL* = SC + 4; (* peripheral reset control *)
					SYSPLLCTRL* = SC + 8; (* system PLL control *)
					SYSPLLSTAT* = SC + 0CH; (* system PLL status *)
					SYSOSCCTRL* = SC + 20H; (* system oscillator control *)
					WDTOSCCTRL* = SC + 24H; (* watchdog oscillator control *)
					IRCCTRL* = SC + 28H; (* IRC control *)
					SYSRSTSTAT* = SC + 30H; (* system reset status register *)
					SYSPLLCLKSEL* = SC + 40H; (* system PLL clock source select *)
					SYSPLLCLKUEN* = SC + 44H; (* system PLL clock  source update enable *)
					MAINCLKSEL* = SC + 70H; (* main clock source select *)
					MAINCLKUEN* = SC + 74H; (* main clock source update enable *)
					SYSAHBCLKDIV* = SC + 78H; (* system AHB clock divider *)
					SYSAHBCLKCTRL* = SC + 80H; (* system AHB clock control *)
					SSP0CLKDIV* = SC + 94H; (* SPI0 clock divider *)
					UARTCLKDIV* = SC + 98H; (* UART clock divider *)
					SSP1CLKDIV* = SC + 9CH; (* SPI1 clock divider *)
					WDTCLKSEL* = SC + 0D0H; (* WDT clock source select *)
					WDTCLKUEN* = SC + 0D4H; (* WDT clock source update enable *)
					WDTCLKDIV* = SC + 0D8H; (* WDT clock divider *)
					CLKOUTCLKSEL* = SC + 0E0H; (* CLKOUT clock source select *)
					CLKOUTUEN* = SC + 0E4H; (* CLKOUT clock source update enable *)
					CLKOUTCLKDIV* = SC + 0E8H; (* CLKOUT clock divider *)
					PIOPORCAP0* = SC + 100H; (* POR captured PIO status 0 *)
					PIOPORCAP1* = SC + 104H; (* POR captured PIO status 1 *)
					BODCTRL* = SC + 150H; (* BOD control *)
					SYSTCKCAL* = SC + 154H; (* system tick counter calibration *)
					IRQLATENCY* = SC + 170H; (* IRQ delay. Allow trade-off between interrupt latency and determinism *)
					NMISRC* = SC + 174H; (* NMI source selection *)
					STARTAPRP0* = SC + 200H; (* start logic edge control register 0 *)
					STARTERP0* = SC + 204H; (* start logic signal enable register 0 *)
					STARTRSRP0CLR* = SC + 208H; (* start logic reset register 0 *)
					STARTSRP0* = SC + 20CH; (* start logic status register 0 *)
					PDSLEEPCFG* = SC + 230H; (* power-down states in Deep-sleep mode *)
					PDAWAKECFG* = SC + 234H; (* power-down states after wake-up from Deep-sleep mode *)
					PDRUNCFG* = SC + 238H; (* power-down configuration register *)
					DEVICEID* = SC + 3F4H; (* device ID register 0 for parts LPC1100, LPC1100C, LPC1100L *)
				(* LPC11Cxx *)
					CCAN* = 40050000H;
				(* LPC1100[L] series: LQFP48/LQFP100 packages only *)
					SSP1* = 40058000H;
						SSP1CR0* = SSP1;
