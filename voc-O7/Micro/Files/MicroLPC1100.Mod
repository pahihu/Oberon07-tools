					TMR32B0PWMC* = CT32B0 + 74H;
				CT32B1* = 40018000H;
					TMR32B1IR* = CT32B1;
					TMR32B1TCR* = CT32B1 + 4;
					TMR32B1TC* = CT32B1 + 8;
					TMR32B1PR* = CT32B1 + 0CH;
					TMR32B1PC* = CT32B1 + 10H;
					TMR32B1MCR* = CT32B1 + 14H;
					TMR32B1MR0* = CT32B1 + 18H;
					TMR32B1MR1* = CT32B1 + 1CH;
